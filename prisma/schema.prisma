// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model SiteConfig {
  id            String   @id @default("main")
  serverIP      String   @default("minewar.ddns.net")
  discordUrl    String   @default("https://discord.gg/xHUGYn7ErC")
  modrinthUrl   String   @default("https://github.com/Minher0/Minewar/releases/latest/download/MineWar.1.0.0.mrpack")
  curseforgeUrl String   @default("https://github.com/Minher0/Minewar/releases/latest/download/MineWar.zip")
  updatedAt     DateTime @updatedAt
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
